{
  "manifest_version": 3,
  "name": "WFM Price History",
  "version": "1.1.0",
  "description": "Embeds price history charts, forecasts, liquidity scores and trade alerts directly into every warframe.market item page.",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://warframe.market/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://api.warframe.market/*"
  ],
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon.png"
  }
}
